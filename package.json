{
  "name": "pi-dash",
  "version": "0.1.0",
  "description": "Terminal dashboard for monitoring pi coding agent sessions",
  "type": "module",
  "bin": {
    "pi-dash": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "dashboard",
    "tui"
  ],
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.1",
    "chokidar": "^5.0.0",
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
